<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.intellimatch.ui.controller.MainController"
            stylesheets="@../styles/main.css"
            prefWidth="1200" prefHeight="780">

    <!-- ====== TOP BAR ====== -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="10" bottom="10" left="18" right="18"/></padding>
            <Label text="IntelliMatch-X" styleClass="app-title"/>
            <Label text="Automated Bi-Directional Internship Matching" styleClass="app-subtitle"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Algorithm:" styleClass="control-label"/>
            <ComboBox fx:id="strategyComboBox" onAction="#onStrategyChanged" prefWidth="240"/>
        </HBox>
    </top>

    <!-- ====== MAIN CONTENT ====== -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="main-tabs">

            <!-- ===== TAB 1: Bi-Directional Matching ===== -->
            <Tab text="Bi-Directional Matching">
                <VBox spacing="10">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

                    <!-- Action Toolbar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Run Full Bi-Directional Match"
                                onAction="#onRunBidirectionalMatch"
                                styleClass="btn,btn-primary"/>
                        <Separator orientation="VERTICAL"/>
                        <Label text="Applicant:" styleClass="control-label"/>
                        <ComboBox fx:id="applicantComboBox" prefWidth="200"/>
                        <Button text="Get Recommendations"
                                onAction="#onGetApplicantRecommendations"
                                styleClass="btn,btn-success"/>
                        <Separator orientation="VERTICAL"/>
                        <Label text="Recruiter:" styleClass="control-label"/>
                        <ComboBox fx:id="recruiterComboBox" prefWidth="220"/>
                        <Button text="Discover Candidates"
                                onAction="#onGetRecruiterCandidates"
                                styleClass="btn,btn-info"/>
                    </HBox>

                    <!-- Results Table -->
                    <TableView fx:id="matchTableView" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colApplicant" text="Applicant" prefWidth="150"/>
                            <TableColumn fx:id="colRecruiter" text="Internship Role" prefWidth="220"/>
                            <TableColumn fx:id="colCompany"   text="Company" prefWidth="160"/>
                            <TableColumn fx:id="colScore"     text="Match Score" prefWidth="110"/>
                            <TableColumn fx:id="colMatchedSkills" text="Matched Skills" prefWidth="320"/>
                        </columns>
                        <placeholder>
                            <Label text="Click 'Run Full Bi-Directional Match' to start" styleClass="placeholder-label"/>
                        </placeholder>
                    </TableView>

                    <!-- Justification Panels -->
                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Match Justification — Applicant Perspective" styleClass="section-header"/>
                            <TextArea fx:id="applicantJustificationArea" editable="false"
                                      prefHeight="160" wrapText="true" styleClass="justification-area"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Match Justification — Recruiter Perspective" styleClass="section-header"/>
                            <TextArea fx:id="recruiterJustificationArea" editable="false"
                                      prefHeight="160" wrapText="true" styleClass="justification-area"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <!-- ===== TAB 2: Explainability Dashboard (WebView) ===== -->
            <Tab text="Explainability Dashboard">
                <VBox spacing="0">
                    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
                    <Label text="  Visual Explainability Dashboard (HTML/JS) — select a match result in Tab 1 to populate"
                           styleClass="webview-hint"/>
                    <WebView fx:id="explainabilityWebView" VBox.vgrow="ALWAYS" prefHeight="680"/>
                </VBox>
            </Tab>

            <!-- ===== TAB 3: Notifications ===== -->
            <Tab text="Real-Time Notifications">
                <VBox spacing="8">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label text="Observer-Pattern Notification Feed (Applicant + Recruiter Alerts)"
                           styleClass="section-header"/>
                    <ListView fx:id="notificationListView" VBox.vgrow="ALWAYS" styleClass="notification-list"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>

    <!-- ====== STATUS BAR ====== -->
    <bottom>
        <HBox styleClass="statusbar" alignment="CENTER_LEFT">
            <padding><Insets top="6" bottom="6" left="14" right="14"/></padding>
            <Label fx:id="statusLabel" text="Ready"/>
        </HBox>
    </bottom>

</BorderPane>
