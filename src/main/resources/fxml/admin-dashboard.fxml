<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.intellimatch.ui.controller.AdminDashboardController"
            stylesheets="@../styles/main.css"
            prefWidth="1200" prefHeight="780"
            styleClass="admin-page">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="10" bottom="10" left="18" right="18"/></padding>
            <Label text="IntelliMatch-X" styleClass="app-title"/>
            <Label text="Admin Analytics Dashboard" styleClass="app-subtitle"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#onRefresh" styleClass="auth-action-btn,auth-action-primary"/>
            <Button text="Back" onAction="#onBack" styleClass="btn,btn-default"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

            <HBox styleClass="admin-summary-row">
                <VBox spacing="4" styleClass="admin-stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <Label text="Signed Up Users" styleClass="admin-stat-title"/>
                    <Label fx:id="signedUpLabel" styleClass="admin-stat-value"/>
                </VBox>
                <VBox spacing="4" styleClass="admin-stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <Label text="Active Users" styleClass="admin-stat-title"/>
                    <Label fx:id="activeLabel" styleClass="admin-stat-value"/>
                </VBox>
                <VBox spacing="4" styleClass="admin-stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <Label text="Shortlisted Candidates" styleClass="admin-stat-title"/>
                    <Label fx:id="shortlistedLabel" styleClass="admin-stat-value"/>
                </VBox>
                <VBox spacing="4" styleClass="admin-stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <Label text="Marketplace Size" styleClass="admin-stat-title"/>
                    <Label fx:id="candidateCountLabel" styleClass="admin-stat-value"/>
                    <Label fx:id="recruiterCountLabel" styleClass="control-label"/>
                </VBox>
            </HBox>

            <Label fx:id="conversionLabel" text="Conversion funnel" styleClass="admin-conversion-pill"/>

            <HBox spacing="10" VBox.vgrow="ALWAYS">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Top Candidate Skills (Supply)" styleClass="section-header"/>
                    <TableView fx:id="topSkillsTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="topRankCol" text="#" prefWidth="56"/>
                            <TableColumn fx:id="topMetricCol" text="Skill" prefWidth="180"/>
                            <TableColumn fx:id="topCountCol" text="Mentions" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Market Demand Skills (Recruiter Requirements)" styleClass="section-header"/>
                    <TableView fx:id="demandSkillsTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="demandRankCol" text="#" prefWidth="56"/>
                            <TableColumn fx:id="demandMetricCol" text="Skill" prefWidth="180"/>
                            <TableColumn fx:id="demandCountCol" text="Demand" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Work Mode Demand Trend" styleClass="section-header"/>
                    <TableView fx:id="workModeTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
                        <columns>
                            <TableColumn fx:id="modeRankCol" text="#" prefWidth="56"/>
                            <TableColumn fx:id="modeMetricCol" text="Mode" prefWidth="180"/>
                            <TableColumn fx:id="modeCountCol" text="Openings" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

            <Label fx:id="statusLabel" text="Ready." styleClass="control-label"/>
        </VBox>
    </center>
</BorderPane>
